# Vaultwise configuration
# Copy to .env and fill in values

# Database path (default: vaultwise.db in project root)
VAULTWISE_DB=vaultwise.db

# Server settings
VAULTWISE_HOST=0.0.0.0
VAULTWISE_PORT=8090

# LLM provider for Q&A and generation
# Options: ollama, openai, mock
LLM_PROVIDER=mock

# Ollama settings (when LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT=60

# OpenAI settings (when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ingestion settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
